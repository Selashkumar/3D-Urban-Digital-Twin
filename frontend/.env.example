# Frontend environment variables (copy to .env.local for local dev)

# ── CesiumJS Ion Token ─────────────────────────────────────────────────────────
# FREE at https://cesium.com/ion/signup — sign up, go to Access Tokens, copy default token
# Without this token: app still works but uses OpenStreetMap tiles (no 3D terrain or OSM buildings)
# With this token: real-world terrain, Bing aerial imagery, and 3D OSM buildings (asset 96188)
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ── Backend API URLs ───────────────────────────────────────────────────────────
# Leave empty for local dev — Vite proxy handles /api, /health, /ws automatically
# VITE_API_BASE_URL=
# VITE_WS_BASE_URL=

# ── Production (Azure) ─────────────────────────────────────────────────────────
# Set these in Azure Static Web Apps Application Settings:
# VITE_API_BASE_URL=https://your-app.azurewebsites.net
# VITE_WS_BASE_URL=wss://your-app.azurewebsites.net
# VITE_CESIUM_ION_TOKEN=your_production_token
