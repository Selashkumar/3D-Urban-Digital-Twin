{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/health", "/ws"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/health",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/ws",
      "allowedRoles": ["anonymous"]
    }
  ],
  "globalHeaders": {
    "Access-Control-Allow-Origin": "*"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
