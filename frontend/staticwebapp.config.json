{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/cesium/*"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "mimeTypes": {
    ".gpkg": "application/octet-stream"
  }
}
